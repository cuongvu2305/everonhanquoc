{
  "name": "everonhanquoc",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/generate-build-info.mjs && vite build && node scripts/generate-static-api.mjs",
    "test": "vitest run --exclude tests/build-artifact.test.js",
    "test:build": "npm run build && vitest run tests/build-artifact.test.js",
    "test:watch": "vitest",
    "lint": "eslint .",
    "version:set": "node scripts/set-version.mjs",
    "backend": "python3 backend/app.py",
    "deploy:firebase": "npm run build && npx firebase-tools deploy --only hosting"
  },
  "dependencies": {
    "antd": "5.22.7",
    "firebase": "^12.15.0",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
